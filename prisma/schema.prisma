generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Feature {
  id        String   @id @default(uuid())
  name      String   @unique   // e.g., "Create Bot", "Copy Trade", "Sell on Marketplace"
  website   Website
  createdAt DateTime @default(now())

  roles RoleFeature[]
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique   // admin, seller, affiliate, trader, copyTrader
  website   Website
  createdAt DateTime @default(now())

  usersCrypto CryptoUser[]
  usersStocks StocksUser[]
  features RoleFeature[]
}

model RoleFeature {
  id        String   @id @default(uuid())
  roleId    String
  featureId String

  role    Role    @relation(fields: [roleId], references: [id])
  feature Feature @relation(fields: [featureId], references: [id])

  @@unique([roleId, featureId])
}

model CryptoUser {
  id            String   @id @default(uuid()) 
  email         String   @unique
  name          String?
  phone         String?
  password      String
  roleId        String
  membership    String?  // Free / Starter / Professional / Ultimate
  isVerified    Boolean  @default(false)
  twoFASecret   String?
  twoFAEnabled  Boolean  @default(false)
  createdAt     DateTime @default(now())

  role          Role     @relation(fields: [roleId], references: [id])
  credentials   CryptoCredentials[] 
  kyc           CryptoKYC[]
  cryptoTrades  CryptoTrades[]
}

model StocksUser {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  phone         String?
  password      String
  roleId        String
  membership    String?
  isVerified    Boolean  @default(false)
  twoFASecret   String?
  twoFAEnabled  Boolean  @default(false)
  createdAt     DateTime @default(now())

  role          Role     @relation(fields: [roleId], references: [id])
  credentials   StocksCredentials[]
  kyc           StocksKYC[] 
  stocksTrades  StocksTrades[]

}

enum Website {
  CRYPTO
  STOCKS
}

model CryptoCredentials {
  id             String     @id @default(uuid())
  userId         String
  exchange       CryptoExchange
  apiKey         String
  apiSecret      String
  apiPassphrase  String?
  apiKeyVersion  String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user           CryptoUser @relation(fields: [userId], references: [id])

  @@unique([userId, exchange])
}

model StocksCredentials {
  id            String   @id @default(uuid())
  userId        String
  exchange      String   // "ANGELONE" | "ZERODHA"

  apiKey        String   // Kotak accessToken
  clientCode    String?  // Angel: clientCode | Zerodha: user_id | Kotak: clientCode

  accessToken   String?  // Kotak trading token
  refreshToken  String?  // Angel One only, Kotak sid
  feedToken     String?  // Angel One only, Kotak baseUrl
  dataCenter    String?  // Kotak Only

  expiresAt     DateTime

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          StocksUser @relation(fields: [userId], references: [id])

  @@unique([userId, exchange])
}

model CryptoKYC {
  id         String    @id @default(uuid())
  userId     String
  document   String
  status     KYCStatus @default(PENDING)
  rejectionReason String?
  adminNote       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user CryptoUser @relation(fields: [userId], references: [id])

  @@index([userId])
}


model StocksKYC {
  id         String   @id @default(uuid())
  userId     String   
  document   String
  status     KYCStatus @default(PENDING)
  rejectionReason String?
  adminNote       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user StocksUser @relation(fields: [userId], references: [id])

  @@index([userId])
}





model CryptoTrades {
  id           String      @id @default(uuid())
  userId       String        
  exchange     CryptoExchange
  type         CryptoTradeType
  orderType    String  // "LIMIT" or "MARKET"
  symbol       String
  side         TradeSide
  orderId      String       
  quantity     Float
  price        Float
  triggerPrice Float?
  status       TradeStatus
  fee          Float       @default(0)
  leverage     Float?
  
  realizedPnl   Float           @default(0) // REQUIRED
  executedAt    DateTime        @default(now())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         CryptoUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  order        CryptoOrder? @relation(fields: [orderId], references: [id])

}


model StocksTrades {
  id           String      @id @default(uuid())
  userId       String        
  exchange     StocksExchange
  type         String
  orderType    String  // "LIMIT" or "MARKET"
  symbol       String
  side         TradeSide
  orderId      String       
  quantity     Float
  price        Float
  triggerPrice Float?
  status       TradeStatus
  fee          Float       @default(0)
  leverage     Float?
  
  realizedPnl   Float           @default(0) // REQUIRED
  executedAt    DateTime        @default(now())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         StocksUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  order        StocksOrder? @relation(fields: [orderId], references: [id])

}


model FuturesPosition {
  id             String   @id @default(uuid())
  userId         String
  exchange       CryptoExchange
  symbol         String

  qty            Float    // +long, -short
  avgEntryPrice  Float
  realizedPnl    Float    @default(0)

  updatedAt      DateTime @updatedAt

  @@unique([userId, exchange, symbol])
}

model SpotBalance {
  id            String   @id @default(uuid())
  userId        String
  exchange      CryptoExchange
  asset         String

  qty           Float
  avgPrice      Float
  realizedPnl   Float    @default(0)

  updatedAt     DateTime @updatedAt

  @@unique([userId, exchange, asset])
}

model CryptoOrder {
  id               String   @id @default(uuid())
  userId           String
  exchange         CryptoExchange
  type             CryptoTradeType   // SPOT | FUTURES
  symbol           String
  side             TradeSide          // BUY | SELL

  exchangeOrderId  String?
  clientOrderId    String?

  requestedQty     Float
  requestedPrice   Float?
  leverage         Float?
  orderType        String             // MARKET / LIMIT

  status           TradeStatus         // NEW / PARTIALLY_FILLED / FILLED / CANCELLED
  filledQty        Float               @default(0)

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  trades           CryptoTrades[]

  @@unique([exchangeOrderId])
}

model StocksOrder {
  id               String   @id @default(uuid())
  userId           String
  exchange         StocksExchange
  type             String
  symbol           String
  side             TradeSide          // BUY | SELL

  exchangeOrderId  String?
  clientOrderId    String?

  requestedQty     Float
  requestedPrice   Float?
  leverage         Float?
  orderType        String             // MARKET / LIMIT

  status           TradeStatus         // NEW / PARTIALLY_FILLED / FILLED / CANCELLED
  filledQty        Float               @default(0)

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  trades           StocksTrades[]

  @@unique([exchangeOrderId])
}

model Strategy {
  id           String   @id @default(cuid())
  userId       String

  name         String   // "Growth DCA BTC"
  assetType    String   // CRYPTO | STOCK
  type         String   // GROWTH_DCA
  exchange     String   // BINANCE | KUCOIN | COINDCX | ZERODHA
  segment      String   // SPOT | FUTURES | DELIVERY | CASH
  symbol       String   // BTCUSDT, B-BTC_USDT, RELIANCE

  config       Json     // ALL strategy logic lives here

  status       String   @default("ACTIVE") // ACTIVE | PAUSED | STOPPED
  executionMode StrategyExecutionMode @default(LIVE)

  nextRunAt      DateTime?   // NEW
  lastExecutedAt DateTime?  // NEW

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([exchange, segment, symbol])
  @@index([nextRunAt])
}

// Marketplace
model StrategyPurchase {
  id              String   @id @default(uuid())

  originalStrategyId String
  buyerUserId     String

  forkedStrategyId String

  createdAt       DateTime @default(now())
}



// Copy Trading
model StrategyCopySubscription {
  id             String   @id @default(uuid())
  strategyId     String
  followerUserId String

  multiplier     Float    @default(1) // quantity scaling
  isActive       Boolean  @default(true)

  createdAt      DateTime @default(now())

  @@unique([strategyId, followerUserId])
}


model Notification {
  id          String   @id @default(uuid())
  userId      String

  type        NotificationType
  title       String
  message     String

  severity    NotificationSeverity @default(INFO)

  isRead      Boolean  @default(false)

  meta        Json?    // strategyId, exchange, redirect hints, etc.

  createdAt   DateTime @default(now())
  readAt      DateTime?

  @@index([userId, isRead])
  @@index([type])
}

enum StrategyExecutionMode {
  LIVE
  BACKTEST
  PUBLISHED
}

enum NotificationType {
  STOCKS_SESSION_EXPIRED
  STOCKS_SESSION_EXPIRING_SOON
  STRATEGY_PAUSED
  STRATEGY_RESUMED
  STRATEGY_EXECUTION_FAILED
  TRADE_REJECTED
  SYSTEM_ALERT
}

enum NotificationSeverity {
  INFO
  WARNING
  CRITICAL
}


enum KYCStatus {
  PENDING
  APPROVED
  REJECTED
}


enum CryptoExchange {
  BINANCE
  COINDCX
  KUCOIN
}

enum StocksExchange {
  ZERODHA
  ANGELONE
  KOTAK
}
enum CryptoTradeType {
  SPOT
  FUTURES
}

enum TradeSide {
  BUY
  SELL
}

enum TradeStatus {
  EXECUTED
  PENDING 
  FAILED
  TIMEOUTED
  OPEN
  CANCELLED
  PARTIALLY_FILLED
  REJECTED
}
 